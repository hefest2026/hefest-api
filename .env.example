# --- Core ---
HEFEST_DB_URL=asyncpg://hefest:hefest@localhost:5432/hefest_db
HEFEST_REDIS_URL=redis://localhost:6379
HEFEST_ENV=dev
HEFEST_LOG_LEVEL=DEBUG

# --- JWT / tokens ---
HEFEST_JWT_SECRET=change-me-in-production
HEFEST_JWT_ALGORITHM=HS256
HEFEST_JWT_AUDIENCE=hefest-api
HEFEST_JWT_EXPIRE_MINUTES=15
HEFEST_REFRESH_TOKEN_EXPIRE_DAYS=14
HEFEST_EMAIL_VERIFY_EXPIRE_HOURS=24
# Base URL the email-verification link points at (?token=... is appended)
HEFEST_EMAIL_VERIFY_URL=http://localhost:5173/verify-email

# --- Cookies / CORS / OAuth redirect targets ---
HEFEST_REFRESH_COOKIE_NAME=hefest_refresh
HEFEST_REFRESH_COOKIE_SECURE=true
# Web SSO lands here with the access token in the URL fragment (refresh via cookie)
HEFEST_FRONTEND_OAUTH_SUCCESS_URL=
# Native SSO deeplink (?client=mobile) — both tokens delivered in the fragment.
# Server-controlled; the client only selects web vs mobile, never an arbitrary URL.
HEFEST_MOBILE_OAUTH_SUCCESS_URL=hefestmobile://auth/callback
HEFEST_CORS_ORIGINS=

# --- Google OAuth (leave blank to disable; all three required to enable) ---
HEFEST_GOOGLE_CLIENT_ID=
HEFEST_GOOGLE_CLIENT_SECRET=
HEFEST_GOOGLE_REDIRECT_URI=

# --- Microsoft OAuth / Entra (leave blank to disable; all four required) ---
HEFEST_MICROSOFT_CLIENT_ID=
HEFEST_MICROSOFT_CLIENT_SECRET=
HEFEST_MICROSOFT_TENANT=
HEFEST_MICROSOFT_REDIRECT_URI=

# --- Notification worker (Postgres-outbox driven; separate process) ---
# LISTEN/NOTIFY channel the outbox trigger fires on to wake the worker
HEFEST_WORKER_NOTIFY_CHANNEL=hefest_jobs
HEFEST_WORKER_FALLBACK_POLL_INTERVAL=5.0
HEFEST_WORKER_CLAIM_BATCH_SIZE=50
HEFEST_WORKER_REAPER_IDLE_SECONDS=300
HEFEST_WORKER_REAP_BATCH_SIZE=1000
HEFEST_WORKER_HEARTBEAT_INTERVAL=90
HEFEST_WORKER_MAX_ATTEMPTS=3
HEFEST_WORKER_BACKOFF_BASE_SECONDS=30
HEFEST_WORKER_SEND_CONCURRENCY=10
HEFEST_WORKER_DB_POOL_SIZE=13

# --- SMTP (mailpit in dev, Resend in prod) ---
HEFEST_SMTP_HOST=localhost
HEFEST_SMTP_PORT=1025
HEFEST_SMTP_FROM=noreply@hefest.local
HEFEST_SMTP_USERNAME=
HEFEST_SMTP_PASSWORD=
HEFEST_SMTP_USE_TLS=false
HEFEST_SMTP_TIMEOUT=30

# --- Expo push notifications (HEF-43) ---
HEFEST_EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
HEFEST_EXPO_ACCESS_TOKEN=
HEFEST_EXPO_PUSH_TIMEOUT=10

# --- Networking ---
# Trusted reverse-proxy IPs/CIDRs for ProxyHeadersMiddleware (set to the
# nginx/traefik container IP or CIDR in production)
HEFEST_TRUSTED_PROXIES=127.0.0.1,::1

# --- Rate limiting ---
HEFEST_RATE_LIMIT_LOGIN_COUNT=10
HEFEST_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
HEFEST_RATE_LIMIT_REGISTER_COUNT=5
HEFEST_RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
HEFEST_RATE_LIMIT_EVENT_REGISTER_COUNT=30
HEFEST_RATE_LIMIT_EVENT_REGISTER_WINDOW_SECONDS=60
HEFEST_RATE_LIMIT_GLOBAL_COUNT=200
HEFEST_RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60

# --- Event business rules ---
HEFEST_EVENT_LOCATION_LOCK_HOURS=2
